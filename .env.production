# Variables sugeridas para Render
# Copia estas vars al dashboard del servicio backend

DATABASE_URL=postgresql://postgres:[PASSWORD]@[HOST]:5432/postgres
JWT_SECRET=generar_un_secreto_nuevo_y_seguro
JWT_EXPIRY_HOURS=24

GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=https://ricapinta.netlify.app
OPENROUTER_TITLE=RicaPinta Backend

AI_PROVIDER=auto
AI_MAX_RETRIES=2
AI_RETRY_BASE_MS=1200

NODE_ENV=production
PORT=4000
CORS_ORIGINS=https://ricapinta.netlify.app
LOG_LEVEL=info
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
