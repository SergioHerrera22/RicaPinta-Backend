# Configuración de entorno para RicaPinta Backend

# Base de datos PostgreSQL
# Ejemplo Supabase: postgresql://user:password@host:5432/dbname
# Ejemplo local: postgresql://postgres:postgres@localhost:5432/ricapinta
DATABASE_URL=

# JWT
# Generar con: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
JWT_EXPIRY_HOURS=24

# Google Gemini - SEGURO EN BACKEND
# Obtener de: https://ai.google.dev/
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# OpenRouter (alternativa con modelos gratuitos)
# Obtener de: https://openrouter.ai/
OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_REFERER=
OPENROUTER_TITLE=RicaPinta Backend

# Seleccion de proveedor IA: auto | openrouter | gemini | local
AI_PROVIDER=auto
AI_MAX_RETRIES=2
AI_RETRY_BASE_MS=1200

# Server
NODE_ENV=development
PORT=4000

# CORS - Orígenes permitidos (separados por coma)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Usuarios demo (cambiar en producción)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
VENTAS_USERNAME=ventas
VENTAS_PASSWORD=ventas123
